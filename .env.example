# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=beerflow
POSTGRES_PASSWORD=beerflow_secret
POSTGRES_DB=beerflow

# ─── Redis ────────────────────────────────────────────────────
# Sin contraseña en dev. En producción añadir REDIS_PASSWORD.
REDIS_URL=redis://redis:6379

# ─── MQTT ─────────────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883

# ─── JWT / Autenticación ──────────────────────────────────────
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Admin inicial (seed) ─────────────────────────────────────
# Ejecuta `scripts/create_admin.py` para crear este usuario.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123

# ─── Servicios internos (entre contenedores) ──────────────────
BILLING_SERVICE_URL=http://billing-service:8001
TAP_MANAGEMENT_URL=http://tap-management-service:8002
BEERFLOW_SERVICE_URL=http://beerflow-service:8000

# ─── Frontend (Vite — expuestas al navegador) ─────────────────
VITE_BEERFLOW_WS_URL=ws://localhost:8000
VITE_TAP_MANAGEMENT_URL=http://localhost:8002
VITE_BILLING_URL=http://localhost:8001

# ─── Física del caudalímetro (beerflow-service) ───────────────
# YF-S201: ~450 pulsos/litro → 1 pulso ≈ 2.25 ml
ML_PER_PULSE=2.25
# Segundos sin flujo para cerrar sesión automáticamente
SESSION_TIMEOUT_SECONDS=5

# ─── Simulador ESP32 (solo desarrollo) ────────────────────────
TAP_ID=tap-001
PULSE_INTERVAL_MS=200

VITE_BEERFLOW_WS_URL=ws://localhost:8000
VITE_TAP_MANAGEMENT_URL=http://localhost:8002
VITE_BILLING_URL=http://localhost:8001

# ─── Stripe (producción; dejar vacío en dev) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
