# ─────────────────────────────────────────────────────────────
# BeerFlow — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=beerflow
POSTGRES_PASSWORD=beerflow_secret
POSTGRES_DB=beerflow

# Redis (sin contraseña en dev; en producción añadir REDIS_PASSWORD)
REDIS_URL=redis://redis:6379

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883

# Servicios internos (usados entre contenedores)
BILLING_SERVICE_URL=http://billing-service:8001
TAP_MANAGEMENT_URL=http://tap-management-service:8002

# Frontend (Vite — expuestas al navegador)
VITE_BEERFLOW_WS_URL=ws://localhost:8000
VITE_TAP_MANAGEMENT_URL=http://localhost:8002

# Precios y física del caudalímetro
# YF-S201: ~450 pulsos/litro → 1 pulso ≈ 2.22 ml
ML_PER_PULSE=2.22
# Segundos sin flujo para cerrar la sesión automáticamente
SESSION_TIMEOUT_SECONDS=3

# Stripe (billing — dejar vacío en dev para usar modo prepago)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
